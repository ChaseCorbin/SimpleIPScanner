<Window x:Class="SimpleIPScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IP Scanner &amp; DNS Benchmark — By Chase Corbin"
        Icon="Assets/app.ico"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryDarkBrush}"
        Closing="MainWindow_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="24,18,24,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D1117" Offset="0"/>
                    <GradientStop Color="#1C2333" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Switch stack logo (vector, no external image) -->
                    <Viewbox Height="40" VerticalAlignment="Center" Margin="0,0,14,0" Stretch="Uniform">
                        <Canvas Width="54" Height="36">
                            <!-- Stacking bracket -->
                            <Rectangle Canvas.Left="0" Canvas.Top="3" Width="2" Height="30"
                                       Fill="{StaticResource AccentCyanBrush}" RadiusX="1" RadiusY="1"/>

                            <!-- Switch 1 — top, inactive -->
                            <Rectangle Canvas.Left="4" Canvas.Top="0" Width="48" Height="10"
                                       Fill="{StaticResource CardDarkBrush}" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="0" Width="48" Height="10"
                                       Fill="Transparent" Stroke="{StaticResource BorderDarkBrush}"
                                       StrokeThickness="0.8" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="9"  Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="15" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="21" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="27" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="33" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="39" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Ellipse   Canvas.Left="46" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource OfflineGrayBrush}"/>

                            <!-- Switch 2 — middle, partial -->
                            <Rectangle Canvas.Left="4" Canvas.Top="13" Width="48" Height="10"
                                       Fill="{StaticResource CardDarkBrush}" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="13" Width="48" Height="10"
                                       Fill="Transparent" Stroke="{StaticResource BorderDarkBrush}"
                                       StrokeThickness="0.8" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="9"  Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="15" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="21" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="27" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="33" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="39" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource BorderDarkBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Ellipse   Canvas.Left="46" Canvas.Top="16" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" Opacity="0.5"/>

                            <!-- Switch 3 — bottom, fully active -->
                            <Rectangle Canvas.Left="4" Canvas.Top="26" Width="48" Height="10"
                                       Fill="{StaticResource CardDarkBrush}" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="26" Width="48" Height="10"
                                       Fill="Transparent" Stroke="{StaticResource AccentCyanBrush}"
                                       StrokeThickness="1" RadiusX="2" RadiusY="2"/>
                            <Rectangle Canvas.Left="9"  Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="15" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="21" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="27" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="33" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Rectangle Canvas.Left="39" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            <Ellipse   Canvas.Left="46" Canvas.Top="29" Width="4" Height="4" Fill="{StaticResource AccentCyanBrush}"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="IP Scanner" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                        <TextBlock Text="By Chase Corbin" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                   Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" Background="{StaticResource CardDarkBrush}" CornerRadius="10" Padding="16,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource OnlineGreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="OnlineCountText" Text="0 devices online" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Settings gear button -->
                <Button Grid.Column="3"
                        Content="⚙"
                        FontSize="18"
                        Style="{StaticResource GhostButton}"
                        Padding="10,6"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="Settings"
                        Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <!-- UPDATE BANNER — hidden until an update is available -->
        <Border x:Name="UpdateBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Padding="20,10"
                Background="#1C2B22"
                BorderBrush="{StaticResource AccentCyanBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8"
                         Fill="{StaticResource AccentCyanBrush}"
                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="UpdateBannerText"
                           Grid.Column="1"
                           Text="A new version is available"
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="UpdateNowButton"
                        Grid.Column="2"
                        Content="Update &amp; Restart"
                        Style="{StaticResource ScanButton}"
                        FontSize="12" Padding="16,6" Margin="12,0,8,0"
                        VerticalAlignment="Center"
                        Click="UpdateNowButton_Click"/>
                <Button x:Name="DismissUpdateButton"
                        Grid.Column="3"
                        Content="Dismiss"
                        Style="{StaticResource GhostButton}"
                        FontSize="12" Padding="12,6"
                        VerticalAlignment="Center"
                        Click="DismissUpdateButton_Click"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT TAB CONTROL -->
        <TabControl Grid.Row="2" Margin="0,10,0,0">
            <!-- TAB 1: NETWORK SCANNER -->
            <TabItem Header="Network Scanner">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- INPUT CONTROLS -->
                    <Border Grid.Row="0" Padding="24,12,24,12">
                        <StackPanel>
                            <!-- Top row: subnet entry + action buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Add Subnet:" FontSize="14" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>

                                <TextBox x:Name="CidrInput" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                         VerticalAlignment="Center" KeyDown="CidrInput_KeyDown"/>

                                <Button Grid.Column="2" Content="+ Add" Style="{StaticResource GhostButton}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Click="AddSubnet_Click"/>

                                <Button Grid.Column="3" Content="⊕ Auto-detect" Style="{StaticResource GhostButton}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Click="AutoDetectSubnets_Click"/>

                                <CheckBox x:Name="ShowAllToggle" Grid.Column="4" Content="Show Unreachable"
                                         Style="{StaticResource ModernCheckBox}"
                                         Margin="16,0,0,0" VerticalAlignment="Center"
                                         Checked="FilterToggle_Changed" Unchecked="FilterToggle_Changed"/>

                                <Button x:Name="ScanButton" Grid.Column="5" Content="⚡ Scan"
                                        Style="{StaticResource ScanButton}" Margin="12,0,0,0"
                                        Click="ScanButton_Click" VerticalAlignment="Center"/>

                                <Button x:Name="StopButton" Grid.Column="6" Content="■ Stop"
                                        Style="{StaticResource StopButton}" Margin="8,0,0,0"
                                        Click="StopButton_Click" VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                            </Grid>

                            <!-- Subnet chip list — each chip is a subnet to include in the scan -->
                            <ItemsControl x:Name="SubnetChipList" Margin="0,10,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardDarkBrush}" CornerRadius="6"
                                                Padding="6,4" Margin="0,0,8,4"
                                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Style="{StaticResource ModernCheckBox}"
                                                          Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Cidr}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12" FontFamily="Consolas"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                <Button Content="✕" Click="RemoveSubnet_Click" Tag="{Binding}"
                                                        Style="{StaticResource ChipRemoveButton}"
                                                        FontSize="11" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- PROGRESS -->
                    <Border Grid.Row="1" Padding="24,0,24,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock x:Name="ProgressText" Text="Ready to scan" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"
                                           HorizontalAlignment="Left"/>
                                <TextBlock x:Name="ProgressPercent" Text="" FontSize="12"
                                           Foreground="{StaticResource AccentCyanBrush}" FontFamily="Segoe UI"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <ProgressBar x:Name="ScanProgress" Style="{StaticResource ModernProgressBar}"
                                         Minimum="0" Maximum="100" Value="0"/>
                        </StackPanel>
                    </Border>

                    <!-- RESULTS DATAGRID -->
                    <Grid Grid.Row="2" Margin="24,0,24,24">
                        <Border x:Name="GridMask" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="8"/>
                        <Border x:Name="ResultsContainer" CornerRadius="8" Background="{StaticResource PrimaryDarkBrush}"
                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                            <Border.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=GridMask}"/>
                            </Border.OpacityMask>
                            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserSortColumns="True" CanUserResizeColumns="True"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                      SelectionUnit="FullRow"
                                      Background="Transparent" BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource BorderDarkBrush}"
                                      PreviewMouseRightButtonDown="ResultsGrid_PreviewMouseRightButtonDown"
                                      ContextMenuOpening="ResultsGrid_ContextMenuOpening">

                                <DataGrid.ContextMenu>
                                    <ContextMenu Background="{StaticResource CardDarkBrush}"
                                                 BorderBrush="{StaticResource BorderDarkBrush}"
                                                 BorderThickness="1">
                                        <!-- Override default WPF ContextMenu chrome (removes white outer border/shadow area) -->
                                        <ContextMenu.Template>
                                            <ControlTemplate TargetType="ContextMenu">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="3,3">
                                                    <StackPanel IsItemsHost="True"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ContextMenu.Template>
                                        <ContextMenu.Resources>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="14,7"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <!-- Custom template removes the default icon gutter -->
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="MenuItem">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter ContentSource="Header"
                                                                                  RecognizesAccessKey="True"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsHighlighted" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ContextMenu.Resources>
                                        <MenuItem Header="🌐  Open in Browser"            Click="BrowseMenuItem_Click"/>
                                        <MenuItem Header="🌙  Wake on LAN"               Click="WolMenuItem_Click"/>
                                        <MenuItem Header="🖥  Remote Desktop (RDP)"     Click="RdpMenuItem_Click"/>
                                        <MenuItem Header="⚡  PowerShell Remote Session" Click="PsRemoteMenuItem_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>

                                <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🔄" FontSize="14" Cursor="Hand" ToolTip="Re-scan this IP"
                                                    Click="RescanButton_Click" Tag="{Binding}" Padding="6,3">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource CardDarkBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Status" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource OfflineGrayBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource OnlineGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource OfflineGrayBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource OnlineGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="IP Address" Width="150" SortMemberPath="SortKey">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding IPDisplay, Mode=OneWay}"
                                                     IsReadOnly="True" IsTabStop="False"
                                                     FocusVisualStyle="{x:Null}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontFamily="Segoe UI" FontSize="13"
                                                     Padding="0" VerticalAlignment="Center"
                                                     CaretBrush="{StaticResource AccentCyanBrush}"
                                                     SelectionBrush="{StaticResource AccentCyanDarkBrush}"
                                                     Cursor="IBeam"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Hostname" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Hostname, Mode=OneWay}"
                                                     IsReadOnly="True" IsTabStop="False"
                                                     FocusVisualStyle="{x:Null}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontFamily="Segoe UI" FontSize="13"
                                                     Padding="0" VerticalAlignment="Center"
                                                     CaretBrush="{StaticResource AccentCyanBrush}"
                                                     SelectionBrush="{StaticResource AccentCyanDarkBrush}"
                                                     Cursor="IBeam"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="MAC Address" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding MAC, Mode=OneWay}"
                                                     IsReadOnly="True" IsTabStop="False"
                                                     FocusVisualStyle="{x:Null}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontFamily="Segoe UI" FontSize="13"
                                                     Padding="0" VerticalAlignment="Center"
                                                     CaretBrush="{StaticResource AccentCyanBrush}"
                                                     SelectionBrush="{StaticResource AccentCyanDarkBrush}"
                                                     Cursor="IBeam"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Vendor" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Vendor, Mode=OneWay}"
                                                     IsReadOnly="True" IsTabStop="False"
                                                     FocusVisualStyle="{x:Null}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource AccentCyanBrush}"
                                                     FontFamily="Segoe UI" FontSize="13"
                                                     Padding="0" VerticalAlignment="Center"
                                                     CaretBrush="{StaticResource AccentCyanBrush}"
                                                     SelectionBrush="{StaticResource AccentCyanDarkBrush}"
                                                     Cursor="IBeam"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Details →" Tag="{Binding}"
                                                    Click="DetailsButton_Click"
                                                    Style="{StaticResource DetailsLinkButton}"
                                                    ToolTip="View device details"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- DEVICE DETAIL PANEL -->
                    <Border x:Name="DeviceDetailPanel" Visibility="Collapsed"
                            CornerRadius="8" Background="{StaticResource PrimaryDarkBrush}"
                            BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="24,20,24,24">

                                <!-- Top bar: Back + Re-scan -->
                                <Grid Margin="0,0,0,20">
                                    <Button Content="← Back to Results" HorizontalAlignment="Left"
                                            Style="{StaticResource GhostButton}" Padding="12,6"
                                            Click="BackButton_Click"/>
                                    <Button x:Name="DetailRescanButton" Content="↺  Re-scan Device"
                                            HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                            Padding="12,6" Click="DetailRescanButton_Click"/>
                                </Grid>

                                <!-- Device header: OS icon + hostname + status summary -->
                                <StackPanel Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Path x:Name="DetailOSIcon" Fill="{StaticResource TextSecondaryBrush}"
                                              Width="20" Height="20" Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="DetailHostname" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="DetailStatusDot" Width="8" Height="8"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="DetailStatusText" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="  ·  " FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="DetailPingText" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Info cards row -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Identity card -->
                                    <Border Grid.Column="0" Background="{StaticResource CardDarkBrush}"
                                            CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="NETWORK IDENTITY" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock Text="IP Address" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailIP" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Hostname" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailHostnameFull" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="MAC Address" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailMAC" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Vendor" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailVendor" FontSize="14"
                                                       Foreground="{StaticResource AccentCyanBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Connectivity card -->
                                    <Border Grid.Column="2" Background="{StaticResource CardDarkBrush}"
                                            CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="CONNECTIVITY" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentCyanBrush}"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock Text="Status" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Ellipse x:Name="DetailStatusDot2" Width="8" Height="8"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="DetailStatusText2" FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="Round-Trip Ping" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailPingFull" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Operating System" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailOS" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Subnet" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DetailSubnet" FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Open Ports card -->
                                <Border Background="{StaticResource CardDarkBrush}"
                                        CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="DetailPortsHeader" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   Margin="0,0,0,12"/>
                                        <WrapPanel x:Name="DetailPortsWrap"/>
                                        <TextBlock x:Name="DetailNoPortsText" Text="No open ports detected"
                                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Actions card -->
                                <Border Background="{StaticResource CardDarkBrush}"
                                        CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="QUICK ACTIONS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   Margin="0,0,0,12"/>
                                        <WrapPanel>
                                            <Button Content="🖥  Remote Desktop (RDP)" Style="{StaticResource GhostButton}"
                                                    Click="DetailRdpButton_Click" Padding="14,8" Margin="0,0,8,8"/>
                                            <Button Content="⚡  PowerShell Remote" Style="{StaticResource GhostButton}"
                                                    Click="DetailPsRemoteButton_Click" Padding="14,8" Margin="0,0,8,8"/>
                                            <Button Content="🌐  Open in Browser" Style="{StaticResource GhostButton}"
                                                    Click="DetailBrowseButton_Click" Padding="14,8" Margin="0,0,8,8"/>
                                            <Button x:Name="DetailWolButton" Content="🌙  Wake on LAN"
                                                    Style="{StaticResource GhostButton}"
                                                    Click="DetailWolButton_Click" Padding="14,8" Margin="0,0,8,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Grid>
        </TabItem>

            <!-- TAB 2: DNS BENCHMARK -->
            <TabItem Header="DNS Benchmark">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="24,12,24,16">
                        <StackPanel>
                            <TextBlock Text="DNS Server Latency Test" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="This tests the response time of various DNS servers. 'Uncached' queries bypass local and resolver caches using unique subdomains." 
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Test Duration:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <ComboBox x:Name="DnsTestDuration" Grid.Column="1" Width="120" Style="{StaticResource ModernComboBox}" SelectedIndex="1">
                                    <ComboBoxItem Content="5 Seconds" Tag="5"/>
                                    <ComboBoxItem Content="15 Seconds" Tag="15"/>
                                    <ComboBoxItem Content="30 Seconds" Tag="30"/>
                                </ComboBox>
                                
                                <Button x:Name="StartDnsBenchmarkBtn" Grid.Column="3" Content="🚀 Start Benchmark" Style="{StaticResource ScanButton}" Click="StartDnsBenchmark_Click"/>
                                <Button x:Name="StopDnsBenchmarkBtn" Grid.Column="3" Content="■ Stop" Style="{StaticResource StopButton}" Click="StopDnsBenchmark_Click" Visibility="Collapsed"/>
                            </Grid>

                            <!-- Custom DNS Server Input -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Custom Servers:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>

                                <!-- IP Address input with placeholder -->
                                <Grid Grid.Column="1">
                                    <TextBox x:Name="CustomDnsIp" Style="{StaticResource ModernTextBox}" Padding="8,6" FontSize="12"/>
                                    <TextBlock Text="IP Address" IsHitTestVisible="False" FontSize="12" Margin="10,0,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=CustomDnsIp}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Name input with placeholder -->
                                <Grid Grid.Column="3">
                                    <TextBox x:Name="CustomDnsName" Style="{StaticResource ModernTextBox}" Padding="8,6" FontSize="12"/>
                                    <TextBlock Text="Name (optional)" IsHitTestVisible="False" FontSize="12" Margin="10,0,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=CustomDnsName}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="5" Content="+ Add" Style="{StaticResource ScanButton}" Padding="12,6" Click="AddCustomDnsServer_Click"/>
                            </Grid>

                            <!-- Added custom servers shown as removable chips -->
                            <ItemsControl x:Name="CustomDnsServersList" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SecondaryDarkBrush}" BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,6,4">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Button Content="×" Tag="{Binding}" Click="RemoveCustomDnsServer_Click"
                                                        Style="{StaticResource ChipRemoveButton}"
                                                        FontSize="13" Padding="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="24,0,24,12">
                        <ProgressBar x:Name="DnsBenchmarkProgress" Style="{StaticResource ModernProgressBar}"/>
                    </Border>

                    <!-- DNS RESULTS DATAGRID -->
                    <Grid Grid.Row="2" Margin="24,0,24,24">
                        <Border x:Name="DnsGridMask" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="8"/>
                        <Border CornerRadius="8" Background="{StaticResource PrimaryDarkBrush}" 
                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                            <Border.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=DnsGridMask}"/>
                            </Border.OpacityMask>
                            <DataGrid x:Name="DnsResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                                      Background="Transparent" BorderThickness="0">
                                <DataGrid.Columns>
                                <DataGridTextColumn Header="DNS Provider" Binding="{Binding ServerName}" Width="*"/>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding ServerIp}" Width="120"/>
                                <DataGridTemplateColumn Header="Standard (Cached)" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AverageLatencyCached, StringFormat={}{0:F2} ms}" FontWeight="Bold" Foreground="{StaticResource OnlineGreenBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Live (Uncached)" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AverageLatencyUncached, StringFormat={}{0:F2} ms}" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Min" Binding="{Binding MinLatencyCached, StringFormat={}{0:F1} ms}" Width="80"/>
                                <DataGridTextColumn Header="Max" Binding="{Binding MaxLatencyCached, StringFormat={}{0:F1} ms}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 3: VISUAL TRACEROUTE -->
            <TabItem Header="Visual Traceroute">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar: Targets -->
                    <Border Grid.Column="0" Background="{StaticResource SecondaryDarkBrush}" BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="60"/>
                                <RowDefinition Height="0"/>
                                <RowDefinition Height="0"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="16" Background="{StaticResource CardDarkBrush}">
                                <StackPanel>
                                    <TextBlock Text="Monitored Hosts" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewTraceTarget" Style="{StaticResource ModernTextBox}" Padding="8,6" Text="8.8.8.8"/>
                                        <Button Grid.Column="1" Content="+" Click="AddTraceTarget_Click" Width="32" Margin="8,0,0,0" Style="{StaticResource ScanButton}" Padding="0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="TraceTargetsList" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="8" SelectionChanged="TraceTarget_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TargetCard" Background="{StaticResource CardDarkBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,8" BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Destination}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        <TextBlock Text=" | " FontSize="11" Foreground="{StaticResource BorderDarkBrush}" Margin="4,0"/>
                                                        <TextBlock Text="{Binding AverageLatency, StringFormat={}{0:F0}ms avg}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        <TextBlock Text=" | " FontSize="11" Foreground="{StaticResource BorderDarkBrush}" Margin="4,0"/>
                                                        <TextBlock Text="{Binding PacketLoss, StringFormat={}{0:F1}% loss}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕" Click="DeleteTraceTarget_Click" Style="{StaticResource ChipRemoveButton}" FontSize="13" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter TargetName="TargetCard" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                                <Setter TargetName="TargetCard" Property="BorderThickness" Value="2,1,1,1"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Drag handle between target list and Route Path -->
                            <GridSplitter x:Name="SidebarSplitter" Grid.Row="2"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                                          Background="{StaticResource BorderDarkBrush}" Cursor="SizeNS"
                                          Height="5"/>

                            <!-- Route Path hop panel — shown when a session is selected -->
                            <Border x:Name="SidebarHopSection" Grid.Row="3"
                                    BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,0,0"
                                    Background="{StaticResource SecondaryDarkBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="12,10,12,6">
                                        <TextBlock Text="Route Path" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Destination}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Hops}" Margin="8,0,8,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="4,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="52"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding HopNumber}" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                                            <TextBlock Text="{Binding IP}" FontSize="11" FontFamily="Consolas"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Hostname}" FontSize="9"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding Latency, StringFormat={}{0}ms}"/>
                                                                    <Setter Property="Foreground" Value="{Binding Latency, Converter={StaticResource HopLatencyColorConverter}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTimeout}" Value="True">
                                                                            <Setter Property="Text" Value="*"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource OfflineGrayBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="4" Padding="16" Background="{StaticResource CardDarkBrush}">
                                <Button Content="▶ Start All" Style="{StaticResource ScanButton}" Click="StartAllTraces_Click"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Main Area: Charts -->
                    <Grid x:Name="TraceDetailArea" Grid.Column="1">
                        <!-- All-Sessions Chart Scroll Area (full height) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="AllChartsControl" Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="24,12,24,0" CornerRadius="8"
                                                Background="{StaticResource CardDarkBrush}"
                                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                                                Padding="14,12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="100"/>
                                                    <RowDefinition Height="16"/>
                                                </Grid.RowDefinitions>

                                                <!-- Header: host name + stats + start/stop -->
                                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Destination}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="  ·  " FontSize="10" Foreground="{StaticResource BorderDarkBrush}"/>
                                                            <TextBlock Text="{Binding AverageLatency, StringFormat={}{0:F0}ms avg}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="  ·  " FontSize="10" Foreground="{StaticResource BorderDarkBrush}"/>
                                                            <TextBlock Text="{Binding PacketLoss, StringFormat={}{0:F1}% loss}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Click="ToggleTraceCard_Click" Padding="12,5" FontSize="12" VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource ScanButton}">
                                                                <Setter Property="Content" Value="▶ Resume"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Content" Value="■ Stop"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="btnBorder" CornerRadius="8" Padding="{TemplateBinding Padding}" Background="{StaticResource ErrorRedBrush}">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource ErrorRedDarkBrush}"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>

                                                <!-- Controls: interval buttons + pause + back-to-live -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6" Padding="2"
                                                            BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <RadioButton Content="1m" Tag="1" Click="Interval_Click">
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TimelineRadioButtonStyle}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ChartIntervalMinutes}" Value="1">
                                                                                <Setter Property="IsChecked" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                            <RadioButton Content="5m" Tag="5" Click="Interval_Click">
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TimelineRadioButtonStyle}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ChartIntervalMinutes}" Value="5">
                                                                                <Setter Property="IsChecked" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                            <RadioButton Content="10m" Tag="10" Click="Interval_Click">
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TimelineRadioButtonStyle}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ChartIntervalMinutes}" Value="10">
                                                                                <Setter Property="IsChecked" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                            <RadioButton Content="1h" Tag="60" Click="Interval_Click">
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TimelineRadioButtonStyle}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ChartIntervalMinutes}" Value="60">
                                                                                <Setter Property="IsChecked" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                            <RadioButton Content="2h" Tag="120" Click="Interval_Click">
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TimelineRadioButtonStyle}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ChartIntervalMinutes}" Value="120">
                                                                                <Setter Property="IsChecked" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                        </StackPanel>
                                                    </Border>
                                                    <ToggleButton IsChecked="{Binding IsPaused, Mode=TwoWay}" Padding="10,4" Margin="8,0,0,0" Cursor="Hand">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton" BasedOn="{StaticResource TimelineToggleButtonStyle}">
                                                                <Setter Property="Content" Value="⏸ Pause"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter Property="Content" Value="▶ Resume"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource OnlineGreenBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                    </ToggleButton>
                                                    <Button Content="↩ Live" Padding="10,4" Margin="6,0,0,0" Cursor="Hand"
                                                            Click="BackToLiveBtn_Click"
                                                            Visibility="{Binding IsLive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Content="⊟ Reset Zoom" Padding="10,4" Margin="6,0,0,0" Cursor="Hand"
                                                            Click="ResetZoomBtn_Click"
                                                            Visibility="{Binding IsZoomed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                                <Setter Property="Foreground" Value="{StaticResource WarningOrangeBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource WarningOrangeBrush}"/>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Chart area -->
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Y-Axis Labels -->
                                                    <Grid Grid.Column="0">
                                                        <TextBlock Text="{Binding MaxLatencyValue, StringFormat={}{0:F0}}" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="0" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </Grid>

                                                    <!-- Chart Canvas -->
                                                    <Border Grid.Column="1" BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1,0,0,1">
                                                        <Grid x:Name="ChartContainer" ClipToBounds="True" Background="Transparent" Cursor="Cross"
                                                              MouseMove="ChartCard_MouseMove" MouseLeave="ChartCard_MouseLeave"
                                                              MouseLeftButtonDown="ChartCard_MouseLeftButtonDown"
                                                              MouseLeftButtonUp="ChartCard_MouseLeftButtonUp"
                                                              MouseRightButtonDown="ChartCard_MouseRightButtonDown"
                                                              MouseRightButtonUp="ChartCard_MouseRightButtonUp">
                                                            <Border BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,1,0,0" Height="1" VerticalAlignment="Center" Opacity="0.3"/>
                                                            <!-- Threshold zone -->
                                                            <Canvas IsHitTestVisible="False">
                                                                <Rectangle Fill="{StaticResource ErrorRedBrush}" Opacity="0.05"
                                                                           Width="{Binding ActualWidth, ElementName=ChartContainer}">
                                                                    <Rectangle.Height>
                                                                        <MultiBinding Converter="{StaticResource LatencyToCoordinateConverter}">
                                                                            <Binding Source="100"/>
                                                                            <Binding Path="MaxLatencyValue"/>
                                                                            <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        </MultiBinding>
                                                                    </Rectangle.Height>
                                                                </Rectangle>
                                                                <Line X1="0" X2="{Binding ActualWidth, ElementName=ChartContainer}"
                                                                      Stroke="{StaticResource WarningOrangeBrush}" StrokeThickness="1" StrokeDashArray="4,4" Opacity="0.4">
                                                                    <Line.Y1>
                                                                        <MultiBinding Converter="{StaticResource LatencyToCoordinateConverter}">
                                                                            <Binding Source="100"/>
                                                                            <Binding Path="MaxLatencyValue"/>
                                                                            <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        </MultiBinding>
                                                                    </Line.Y1>
                                                                    <Line.Y2><Binding Path="Y1" RelativeSource="{RelativeSource Self}"/></Line.Y2>
                                                                </Line>
                                                                <TextBlock Text="100ms" FontSize="8" Foreground="{StaticResource WarningOrangeBrush}" Opacity="0.6" Margin="4,-11,0,0">
                                                                    <Canvas.Top>
                                                                        <MultiBinding Converter="{StaticResource LatencyToCoordinateConverter}">
                                                                            <Binding Source="100"/>
                                                                            <Binding Path="MaxLatencyValue"/>
                                                                            <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        </MultiBinding>
                                                                    </Canvas.Top>
                                                                </TextBlock>
                                                            </Canvas>
                                                            <!-- Line chart -->
                                                            <Polyline StrokeThickness="0.8" StrokeLineJoin="Round"
                                                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                                <Polyline.Stroke>
                                                                    <MultiBinding Converter="{StaticResource LatencyToBrushConverter}">
                                                                        <Binding Path="MaxLatencyValue"/>
                                                                        <Binding Path="FilteredHistoryCount"/>
                                                                    </MultiBinding>
                                                                </Polyline.Stroke>
                                                                <Polyline.Points>
                                                                    <MultiBinding Converter="{StaticResource LatencyToPointsConverter}">
                                                                        <Binding Path="FilteredHistory"/>
                                                                        <Binding Path="ActualWidth" ElementName="ChartContainer"/>
                                                                        <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        <Binding Path="MaxLatencyValue"/>
                                                                        <Binding Path="ViewStart"/>
                                                                        <Binding Path="ViewEnd"/>
                                                                    </MultiBinding>
                                                                </Polyline.Points>
                                                            </Polyline>
                                                            <!-- Event marker overlays: vertical 1-px lines at exact event timestamps.    -->
                                                            <!-- Red  = timeout (latency < 0).  Orange = spike (latency ≥ 100 ms).        -->
                                                            <!-- Only appear for archived data; recent pings are already on the polyline. -->
                                                            <Path StrokeThickness="1" Opacity="0.65" IsHitTestVisible="False"
                                                                  Stroke="{StaticResource ErrorRedBrush}">
                                                                <Path.Data>
                                                                    <MultiBinding Converter="{StaticResource EventMarkersConverter}">
                                                                        <Binding Path="FilteredTimeoutEvents"/>
                                                                        <Binding Path="ActualWidth" ElementName="ChartContainer"/>
                                                                        <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        <Binding Path="ViewStart"/>
                                                                        <Binding Path="ViewEnd"/>
                                                                    </MultiBinding>
                                                                </Path.Data>
                                                            </Path>
                                                            <Path StrokeThickness="1" Opacity="0.45" IsHitTestVisible="False"
                                                                  Stroke="{StaticResource WarningOrangeBrush}">
                                                                <Path.Data>
                                                                    <MultiBinding Converter="{StaticResource EventMarkersConverter}">
                                                                        <Binding Path="FilteredSpikeEvents"/>
                                                                        <Binding Path="ActualWidth" ElementName="ChartContainer"/>
                                                                        <Binding Path="ActualHeight" ElementName="ChartContainer"/>
                                                                        <Binding Path="ViewStart"/>
                                                                        <Binding Path="ViewEnd"/>
                                                                    </MultiBinding>
                                                                </Path.Data>
                                                            </Path>
                                                            <!-- Hover tooltip -->
                                                            <Canvas IsHitTestVisible="False">
                                                                <Line x:Name="ChartTooltipLine"
                                                                      Y1="0" Y2="{Binding ActualHeight, ElementName=ChartContainer}"
                                                                      Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"
                                                                      StrokeDashArray="2,2" Visibility="Collapsed"/>
                                                                <Border x:Name="ChartTooltipPopup"
                                                                        Background="{StaticResource PrimaryDarkBrush}"
                                                                        BorderBrush="{StaticResource AccentCyanBrush}" BorderThickness="1"
                                                                        Padding="8,4" CornerRadius="4" Visibility="Collapsed">
                                                                    <StackPanel>
                                                                        <TextBlock x:Name="ChartTooltipTime" Text="00:00:00" FontSize="10"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                        <TextBlock x:Name="ChartTooltipLatency" Text="0ms" FontSize="11"
                                                                                   FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Canvas>
                                                            <!-- Right-click zoom selection overlay -->
                                                            <Canvas x:Name="ZoomSelectionCanvas" IsHitTestVisible="False" Visibility="Collapsed">
                                                                <Rectangle x:Name="ZoomSelectionRect"
                                                                           Fill="{StaticResource AccentCyanBrush}" Opacity="0.15"
                                                                           Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="1"
                                                                           StrokeDashArray="3,2"
                                                                           Height="{Binding ActualHeight, ElementName=ChartContainer}"
                                                                           Width="0"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                                <!-- X-Axis Time Labels -->
                                                <Grid Grid.Row="3" Margin="36,3,0,0">
                                                    <TextBlock Text="{Binding XAxisStartLabel}" FontSize="9" HorizontalAlignment="Left" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding XAxisMidLabel}"   FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding XAxisEndLabel}"   FontSize="9" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- PACKET CAPTURE TAB                                              -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Header="Packet Capture" x:Name="PacketCaptureTab">
                <Grid Background="{StaticResource PrimaryDarkBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Npcap banner -->
                        <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                        <RowDefinition Height="*"/>     <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- ── Npcap missing banner ──────────────────────────────── -->
                    <Border x:Name="NpcapBanner" Grid.Row="0" Visibility="Collapsed"
                            Background="#1A2744" BorderBrush="#2D4A8A"
                            BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚠" FontSize="16"
                                       Foreground="#5B9BD5" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Npcap is required for packet capture"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                    <Run Text="Download and install Npcap (free, by the Nmap Project), then restart the app."/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Download Npcap ↗"
                                    Click="DownloadNpcap_Click"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="12" Padding="14,6" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ── Toolbar ────────────────────────────────────────────── -->
                    <Border Grid.Row="1" Padding="16,12" Background="{StaticResource SecondaryDarkBrush}"
                            BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Interface" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <ComboBox x:Name="CaptureInterfaceCombo" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="CaptureInterfaceCombo_SelectionChanged"/>

                            <Button x:Name="CaptureStartBtn" Grid.Column="2"
                                    Content="▶  Start" Click="CaptureStart_Click"
                                    Style="{StaticResource ScanButton}"
                                    FontSize="12" Padding="16,6" Margin="12,0,0,0"/>

                            <Button x:Name="CaptureStopBtn" Grid.Column="3"
                                    Content="■  Stop" Click="CaptureStop_Click"
                                    Style="{StaticResource StopButton}"
                                    FontSize="12" Padding="16,6" Margin="8,0,0,0"
                                    IsEnabled="False"/>

                            <Button Grid.Column="4" Content="Clear"
                                    Click="CaptureClear_Click"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="12" Padding="14,6" Margin="8,0,0,0"/>

                            <Button Grid.Column="5" Content="Export ↓"
                                    Click="CaptureExport_Click"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="12" Padding="14,6"
                                    HorizontalAlignment="Right" Margin="0,0,16,0"/>

                            <!-- Live stats -->
                            <StackPanel Grid.Column="6" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="CapturePacketsLabel"
                                           Text="0 packets" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock x:Name="CaptureElapsedLabel"
                                           Text="00:00:00" FontSize="11" FontFamily="Consolas"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Top Talkers DataGrid ──────────────────────────────── -->
                    <Border Grid.Row="2" Margin="16" CornerRadius="8"
                            BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                            Background="{StaticResource CardDarkBrush}">
                        <DataGrid x:Name="TalkersGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#0DFFFFFF"
                                  ClipToBounds="True"
                                  RowDetailsVisibilityMode="Collapsed"
                                  LoadingRow="TalkersGrid_LoadingRow">

                            <!-- Per-row style: includes DataGridDetailsPresenter in the template
                                 so the protocol panel can render. DetailsVisibility is managed
                                 in code-behind via LoadingRow + ExpandChevron_Click. -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridRow">
                                                <Border x:Name="RowBorder"
                                                        Background="{TemplateBinding Background}"
                                                        SnapsToDevicePixels="True">
                                                    <StackPanel>
                                                        <DataGridCellsPresenter
                                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                        <DataGridDetailsPresenter
                                                            Visibility="{TemplateBinding DetailsVisibility}"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="RowBorder" Property="Background"
                                                                Value="{StaticResource RowHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="RowBorder" Property="Background"
                                                                Value="{StaticResource CardDarkBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>

                            <!-- Protocol breakdown panel shown when a row is expanded -->
                            <DataGrid.RowDetailsTemplate>
                                <DataTemplate>
                                    <!-- ItemsControl has no scroll logic — mouse-wheel passes
                                         straight through to the outer DataGrid ScrollViewer. -->
                                    <Border Background="#0A000000"
                                            BorderBrush="{StaticResource BorderDarkBrush}"
                                            BorderThickness="0,1,0,1"
                                            Padding="52,8,20,10">
                                        <StackPanel>
                                            <TextBlock Text="TOP PROTOCOLS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding Protocols}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="46"/>   <!-- protocol badge -->
                                                                <ColumnDefinition Width="110"/>  <!-- service name -->
                                                                <ColumnDefinition Width="124"/>  <!-- bar track -->
                                                                <ColumnDefinition Width="76"/>   <!-- bytes -->
                                                                <ColumnDefinition Width="*"/>    <!-- packets -->
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Protocol badge -->
                                                            <Border Grid.Column="0" CornerRadius="3" Padding="5,2"
                                                                    Background="{StaticResource BorderDarkBrush}"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Protocol}"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource AccentCyanBrush}"/>
                                                            </Border>

                                                            <!-- Service / port label -->
                                                            <TextBlock Grid.Column="1" Text="{Binding ServiceName}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Relative bandwidth bar -->
                                                            <Grid Grid.Column="2" Height="4"
                                                                  VerticalAlignment="Center" Margin="8,0">
                                                                <Rectangle Fill="{StaticResource BorderDarkBrush}"
                                                                           HorizontalAlignment="Stretch" RadiusX="2" RadiusY="2"/>
                                                                <Rectangle Width="{Binding BarWidth}" HorizontalAlignment="Left"
                                                                           Fill="{StaticResource AccentCyanBrush}"
                                                                           RadiusX="2" RadiusY="2"/>
                                                            </Grid>

                                                            <!-- Bytes -->
                                                            <TextBlock Grid.Column="3" Text="{Binding BytesDisplay}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- Packets -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding Packets, StringFormat={}{0:N0} pkts}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGrid.RowDetailsTemplate>

                            <DataGrid.Columns>
                                <!-- Expand/collapse chevron -->
                                <DataGridTemplateColumn Width="36" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                                      UpdateSourceTrigger=PropertyChanged}"
                                                          Click="ExpandChevron_Click"
                                                          Width="20" Height="20" Cursor="Hand"
                                                          VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value="▶"/>
                                                        <Setter Property="FontSize" Value="9"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="▼"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Rank -->
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}"
                                                    Width="40" FontSize="11" CanUserSort="False"/>

                                <!-- IP -->
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IP}"
                                                    Width="140" FontSize="12"/>

                                <!-- Hostname -->
                                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}"
                                                    Width="*" FontSize="12"/>

                                <!-- Packets -->
                                <DataGridTextColumn Header="Packets" Binding="{Binding Packets, StringFormat={}{0:N0}}"
                                                    Width="90" FontSize="12"/>

                                <!-- Sent -->
                                <DataGridTextColumn Header="Sent" Binding="{Binding SentDisplay}"
                                                    Width="90" FontSize="12"/>

                                <!-- Received -->
                                <DataGridTextColumn Header="Received" Binding="{Binding ReceivedDisplay}"
                                                    Width="90" FontSize="12"/>

                                <!-- Total with bar -->
                                <DataGridTemplateColumn Header="Total" Width="160" SortMemberPath="TotalBytes">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="4"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{Binding TotalDisplay}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <Grid Grid.Row="1" Background="{StaticResource BorderDarkBrush}"
                                                      Height="3" Margin="0,2,0,0">
                                                    <Rectangle Width="{Binding BarWidth}" HorizontalAlignment="Left"
                                                               Fill="{StaticResource AccentCyanBrush}" RadiusX="1.5" RadiusY="1.5"/>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- SPEED TEST TAB                                                  -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Header="Speed Test">
                <Grid x:Name="SpeedTestRoot" Background="{StaticResource PrimaryDarkBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── Header / Controls ─────────────────────────────────── -->
                    <Border Grid.Row="0" Background="{StaticResource CardDarkBrush}"
                            BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,0,1"
                            Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Internet Speed Test" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Measures download and upload speeds using Cloudflare's test servers. Results may vary with network conditions."
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Duration:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="SpeedDurationCombo" Width="80" Style="{StaticResource ModernComboBox}"
                                          Padding="10,6" Margin="0,0,12,0">
                                    <ComboBoxItem Content="5 s"  Tag="5"/>
                                    <ComboBoxItem Content="10 s" Tag="10" IsSelected="True"/>
                                    <ComboBoxItem Content="20 s" Tag="20"/>
                                </ComboBox>
                                <Button x:Name="StartSpeedTestBtn" Content="▶ Run Test"
                                        Style="{StaticResource ScanButton}" Padding="18,8" FontSize="13"
                                        Click="StartSpeedTest_Click"/>
                                <Button x:Name="StopSpeedTestBtn" Content="■ Stop"
                                        Style="{StaticResource StopButton}" Padding="18,8" FontSize="13"
                                        Click="StopSpeedTest_Click" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Phase label + progress bar ─────────────────────────── -->
                    <Border Grid.Row="1" Padding="24,10,24,8"
                            Background="{StaticResource PrimaryDarkBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding Phase}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ProgressBar x:Name="SpeedProgressBar" Style="{StaticResource ModernProgressBar}"
                                         Value="{Binding Progress}" Height="6"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Main content: chart + stats ───────────────────────── -->
                    <Grid Grid.Row="2" Margin="16,0,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- Chart area -->
                        <Border Grid.Column="0" Background="{StaticResource CardDarkBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                                Margin="0,8,8,0">
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Chart header + legend -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Live Throughput" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Rectangle Width="14" Height="2" Fill="{StaticResource AccentCyanBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Download" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                                        <Rectangle Width="14" Height="2" Fill="{StaticResource WarningOrangeBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Upload" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Drawing area -->
                                <Border Grid.Row="1" MinHeight="120"
                                        BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1,0,0,1">
                                    <Grid x:Name="SpeedChartContainer" ClipToBounds="True" Background="Transparent">
                                        <!-- 50% midline reference -->
                                        <Border BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,1,0,0"
                                                Height="1" VerticalAlignment="Center" Opacity="0.3"/>
                                        <!-- Download polyline (cyan) -->
                                        <Polyline StrokeThickness="1.5" StrokeLineJoin="Round"
                                                  Stroke="{StaticResource AccentCyanBrush}"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Polyline.Points>
                                                <MultiBinding Converter="{StaticResource SpeedToPointsConverter}">
                                                    <Binding Path="DownloadHistory"/>
                                                    <Binding Path="ActualWidth"  ElementName="SpeedChartContainer"/>
                                                    <Binding Path="ActualHeight" ElementName="SpeedChartContainer"/>
                                                    <Binding Path="MaxChartMbps"/>
                                                </MultiBinding>
                                            </Polyline.Points>
                                        </Polyline>
                                        <!-- Upload polyline (orange) -->
                                        <Polyline StrokeThickness="1.5" StrokeLineJoin="Round"
                                                  Stroke="{StaticResource WarningOrangeBrush}"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Polyline.Points>
                                                <MultiBinding Converter="{StaticResource SpeedToPointsConverter}">
                                                    <Binding Path="UploadHistory"/>
                                                    <Binding Path="ActualWidth"  ElementName="SpeedChartContainer"/>
                                                    <Binding Path="ActualHeight" ElementName="SpeedChartContainer"/>
                                                    <Binding Path="MaxChartMbps"/>
                                                </MultiBinding>
                                            </Polyline.Points>
                                        </Polyline>
                                        <!-- Y-axis max label -->
                                        <TextBlock Text="{Binding MaxChartMbps, StringFormat={}{0:F0} Mbps}"
                                                   FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="4,2"/>
                                    </Grid>
                                </Border>

                                <!-- X-axis labels -->
                                <Grid Grid.Row="2" Margin="0,4,0,0">
                                    <TextBlock Text="0s" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding XAxisMidLabel}" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding XAxisEndLabel}" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Stats panel -->
                        <StackPanel Grid.Column="1" Margin="0,8,0,0">

                            <!-- Download card -->
                            <Border Background="{StaticResource CardDarkBrush}" CornerRadius="10"
                                    BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="DOWNLOAD" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DownloadDisplay}" FontSize="28"
                                                   FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Mbps" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </Grid>
                                    <TextBlock Text="{Binding PeakDownloadDisplay}" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Upload card -->
                            <Border Background="{StaticResource CardDarkBrush}" CornerRadius="10"
                                    BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="UPLOAD" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningOrangeBrush}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding UploadDisplay}" FontSize="28"
                                                   FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Mbps" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </Grid>
                                    <TextBlock Text="{Binding PeakUploadDisplay}" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Best ping card -->
                            <Border Background="{StaticResource CardDarkBrush}" CornerRadius="10"
                                    BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="BEST PING" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource OnlineGreenBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding PingDisplay}" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Server latency breakdown -->
                            <TextBlock Text="SERVER LATENCY" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="SpeedPingList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" Padding="10,7"
                                                Background="{StaticResource CardDarkBrush}" CornerRadius="7"
                                                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ServerName}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding IP}" FontSize="9"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="4" Padding="7,3"
                                                        Background="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding LatencyDisplay}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{Binding Latency, Converter={StaticResource HopLatencyColorConverter}}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Padding="24,10" Background="{StaticResource SecondaryDarkBrush}"
                BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusText" Text="Ready"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="ElapsedText" Text=""
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
